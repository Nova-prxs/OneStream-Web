Namespace Workspace.__WsNamespacePrefix.__WsAssemblyName
	Public Class view_check_pnl_cost_centers

        'Declare view and table name
		Dim viewName As String = "XFC_MAIN_VIEW_CHECK_PnLCostCenters"
		Dim tableName As String = "XFC_MAIN_MASTER_CostCentersOldToNew"

		#Region "Get Migration Query"
		
        Public Function GetMigrationQuery(ByVal si As SessionInfo, type As String) As String
            Try
				'Handle type input
				If type.ToLower <> "up" AndAlso type.ToLower <> "down" Then _
					Throw New XFException(si, New Exception("Migration type must be 'up' or 'down'"))
				'Up
				Dim upQuery As String = $"
					IF OBJECT_ID(N'{viewName}', N'V') IS NULL
						BEGIN
						EXEC('CREATE VIEW {viewName} AS
							WITH filtered_pnl_cost_centers AS (
								SELECT DISTINCT cost_center_id, company_id
								FROM XFC_MAIN_FACT_PnLTransactions
								WHERE cost_center_id <> ''none''
							)

							SELECT fpcc.company_id, fpcc.cost_center_id AS id, '''' AS id_old
							FROM filtered_pnl_cost_centers AS fpcc
							LEFT JOIN {tableName} cc
							ON fpcc.cost_center_id = cc.id
							WHERE (cc.id_old IS NULL OR cc.id_old = '''');
						')
						END;
				"
				
				'Down
				Dim downQuery As String = $"
					DROP VIEW IF EXISTS {viewName};
				"
                Return If(type.ToLower = "up", upQuery, downQuery)
            Catch ex As Exception
                Throw New XFException(si, ex)
			End Try
        End Function
		
		#End Region
		
