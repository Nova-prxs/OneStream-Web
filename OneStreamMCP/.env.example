# ============================================================
# OneStream MCP Server Configuration
# ============================================================

# OneStream Connection (required for SQL, error logs, task activity tools)
ONESTREAM_BASE_URL=https://your-server.com/onestreamapi
ONESTREAM_TOKEN=your-bearer-token-or-pat
ONESTREAM_APP_NAME=YourApplicationName
ONESTREAM_ENVIRONMENT=

# Repository Paths (comma-separated)
ONESTREAM_CODEMCP_REPOSITORIES=/path/to/repo1,/path/to/repo2

# SQL Execution (auto-enabled when connection exists)
ONESTREAM_CODEMCP_ENABLE_SQL=true

# OpenAI API Key (optional — enables semantic search)
ONESTREAM_OPENAI_API_KEY=sk-...

# Server
PORT=3000

# API Key for remote access security (recommended)
MCP_API_KEY=your-secret-api-key-here

# Optional paths
# ONESTREAM_CACHE_PATH=/opt/onestream-mcp/.cache
# ONESTREAM_DOCS_PATH=/opt/onestream-mcp/knowledge_base/docs
